#!/usr/bin/env viter
# Full backward neighborhood of the cycle attractor at 1.
build(
    range(1, 30),
    [Rule(lambda x: x % 3 == 0, Op(lambda x: x // 3, label="÷3"))],
    Op(lambda x: x + 2, label="+2"),
    max_depth=None,
    max_nodes=None,
).to_dot(anchor=1, radius=10, direction="backward").render()
