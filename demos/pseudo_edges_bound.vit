#!/usr/bin/env viter
# Pseudo-edges from Rule.bound: doubling stops at 16, tripling at 18.
# Ghost stubs show where expansion was structurally cut off.
viter(
    [1, 5],
    [
        Rule(lambda x: True, Op(lambda x: 2 * x, label="×2"),
             bound=lambda x: 2 * x <= 16),
        Rule(lambda x: True, Op(lambda x: 3 * x, label="×3"),
             bound=lambda x: 3 * x <= 18),
    ],
    None,
    max_depth=None,
    max_nodes=None,
)
