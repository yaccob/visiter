#!/usr/bin/env viter
# Op color stability (a): baseline — two rules + default.
# x // 3 = blue (palette[0]), x + 2 = orange (palette[1]).
build(
    range(1, 30),
    [Rule(lambda x: x % 3 == 0, Op(lambda x: x // 3))],
    Op(lambda x: x + 2),
    max_depth=None,
    max_nodes=None,
).to_dot(anchor=1, radius=10, direction="backward").render()
