#!/usr/bin/env viter
# Iteration on fractions.Fraction values: continued-fraction recurrence
# for the golden ratio: x → 1 + 1/x, starting at 1.
# With exact rational arithmetic the trajectory is
# 1, 2, 3/2, 5/3, 8/5, 13/8, 21/13, 34/21 — Fibonacci-ratio convergents to φ.
(viter([Fraction(1)], max_depth=7, key_type="number")
 .case(lambda x: True, lambda x: 1 + 1 / x)
 .render())
