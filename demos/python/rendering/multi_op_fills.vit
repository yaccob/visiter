#!/usr/bin/env viter
# Multi-op fills: nodes with 2+ outgoing ops get wedged pie-slice fills.
# Node 30 is divisible by 2, 3 AND 5 → three outgoing edges → three slices.
(viter(range(1, 50), max_depth=4)
 .case(lambda x: x % 2 == 0, lambda x: x // 2, label="÷2")
 .case(lambda x: x % 3 == 0, lambda x: x // 3, label="÷3")
 .case(lambda x: x % 5 == 0, lambda x: x // 5, label="÷5")
 .default(lambda x: x + 1, label="+1")
 .render())
