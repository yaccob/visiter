#!/usr/bin/env viter
# Same descent graph with custom op_colors override.
build(
    range(1, 30),
    [Rule(lambda x: x % 3 == 0, Op(lambda x: x // 3, label="÷3"))],
    Op(lambda x: x + 2, label="+2"),
    max_depth=None,
    max_nodes=None,
).to_dot(
    op_colors={"x // 3": "#a83232", "x + 2": "#3266a8"},
).render()
