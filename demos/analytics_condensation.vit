#!/usr/bin/env viter
# Structural simplification via NetworkX: condense strongly-connected
# components into single nodes. The descent graph has two cycles
# (1↔3 and 2→4→6→2); condensation folds each into one node.
import networkx as nx

build(
    range(1, 30),
    [Rule(lambda x: x % 3 == 0, Op(lambda x: x // 3, label="÷3"))],
    Op(lambda x: x + 2, label="+2"),
    max_depth=None,
    max_nodes=None,
).filter(NxFilter(nx.condensation)) \
 .to_dot(node_label_attr="members") \
 .render()
